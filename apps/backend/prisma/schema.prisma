generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BrewMethod {
  POUR_OVER
  OTHER
}

model BrewLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brewedAt   DateTime @default(now())
  title      String
  recipeName String?  // 리스트에 표시할 레시피 이름 (ex. 테츠카츠야 4:6)
  note       String?
  rating     Int?     // 1~5는 앱단 검증

  method BrewMethod @default(POUR_OVER)

  // 레시피 관련 값 (필요한 것만 optional)
  grindSize    String?
  coffeeAmount Float?  // g
  waterAmount  Float?  // g
  waterTemp    Int?    // °C
  brewTimeSec  Int?    // 총 시간(초)
  dripper      String?
  filterType   String?

  steps BrewStep[]
}

model BrewStep {
  id               Int    @id @default(autoincrement())
  brewLogId        Int
  stepNumber       Int
  cumulativeAmount Float  // 누적 물량(g)
  timeSeconds      Int    // 시작 기준 시간(초)

  brewLog BrewLog @relation(fields: [brewLogId], references: [id], onDelete: Cascade)

  @@unique([brewLogId, stepNumber])
}